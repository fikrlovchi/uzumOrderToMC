# Loyiha panel bilan bir xil serverda ishlagani uchun to'g'ridan-to'g'ri
# ilova portiga yuboriladi (nginx/TLS orqali emas) — aks holda certbot'ning
# HTTP->HTTPS redirect'i "Host: 127.0.0.1" so'rovini 404 bilan qaytaradi.
PANEL_INGEST_URL=http://127.0.0.1:3000/api/ingest/runs
PANEL_PROJECT_SLUG=uzum-order-to-mc
PANEL_API_KEY=

# MoySklad API tokeni (panel "O'zgaruvchilar" sahifasidan boshqariladi)
MOYSKLAD_TOKEN=

# MoySklad'da mosi topilmagan SKU haqida ogohlantirish, shuningdek bekor
# qilingan buyurtmalar haqida xabar yuborish uchun (ixtiyoriy)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# Buyurtma Uzumda tasdiqlangach MoySklad holatini qachon "kutish" (hold) va
# qachon "tasdiqlangan" (confirmed) holatiga o'tkazish oralig'i (Toshkent vaqti)
WINDOW_HOLD_START=06:10
WINDOW_HOLD_END=11:00

# Bekor qilingan buyurtma haqida Telegram xabarida belgilanadigan mas'ul odam
CANCEL_NOTIFY_NAME=
CANCEL_NOTIFY_CHAT_ID=

# Uzum kabinetlari va do'konlari (uzum_shop Google Sheet'i "manba" hisoblanadi,
# bu yerga undan import qilinadi). Har bir kabinet uchun:
#   UZUM_TOKEN_<KABINET>          -> Uzum kabinet tokeni
#   UZUM_SHOP_<KABINET>_<BELGI>   -> shu kabinetdagi bitta do'kon ID'si
# <KABINET> nomi ikkala kalitda ham bir xil bo'lishi shart. Bitta kabinetga
# istalgancha do'kon qo'shsa bo'ladi (belgisi ixtiyoriy, faqat takrorlanmasin).
# Bu tokenlar orderFetch (yangi buyurtma), orderStatusSync (Uzum confirm) va
# cancelSync (bekor qilishni aniqlash) — barchasi uchun yagona manba.
UZUM_TOKEN_MAIN=
UZUM_SHOP_MAIN_1=

# Har bir kabinet uchun kunlik Uzum so'rovlari chegarasi — o'zimiz qo'ygan
# xavfsizlik chegarasi (Uzum'ning o'zi 100000/kun ruxsat beradi, tekshirilgan:
# javob sarlavhasi "x-ratelimit-limit-per-day"). Bu qiymatni shundan ancha
# past, lekin 500 kabi haddan tashqari past emas qilib qo'yish kerak.
UZUM_DAILY_REQUEST_LIMIT=50000

# true bo'lsa: Uzum import/tasdiqlash, MoySklad holat o'zgartirish va Telegram
# xabarlari HAQIQIY yuborilmaydi — faqat "nima qilinishi kerak edi" loglanadi.
# Yangi status-sinxronizatsiya funksiyasini birinchi marta ishga tushirishda
# xavfsizlik uchun ishlatiladi.
DRY_RUN=false
